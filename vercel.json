{
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/nuance-review", "destination": "/nuance-review.html" },
    { "source": "/nuance-review.html", "destination": "/nuance-review.html" }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    },
    {
      "source": "/manifest.webmanifest",
      "headers": [
        { "key": "Content-Type", "value": "application/manifest+json" }
      ]
    }
  ]
}
